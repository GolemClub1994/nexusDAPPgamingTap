{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "tonconnect-manifest.json", "use": "@vercel/static" },
    { "src": "icon-192.png", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/tonconnect-manifest.json", "dest": "/tonconnect-manifest.json", "headers": { "Access-Control-Allow-Origin": "*" } },
    { "src": "/icon-192.png", "dest": "/icon-192.png" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
